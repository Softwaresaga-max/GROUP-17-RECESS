<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.educonnect.controller.student.ProfileController">

    <!-- HEADER -->
    <top>
        <HBox spacing="20" style="-fx-padding: 15; -fx-background-color: #2c3e50;">
            <Label text="Student Profile"
                   style="-fx-text-fill: white; -fx-font-size: 18px;"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Button text="Edit Profile" onAction="#editProfile"/>
        </HBox>
    </top>

    <!-- MAIN CONTENT -->
    <center>
        <VBox spacing="15" style="-fx-padding: 20;">

            <Label fx:id="nameLabel" text="Name: --"/>
            <Label fx:id="regLabel" text="Reg No: --"/>
            <Label fx:id="courseLabel" text="Course: --"/>
            <Label fx:id="yearLabel" text="Year: --"/>

            <Separator/>

            <Label fx:id="gpaLabel" text="GPA: --" style="-fx-font-size: 16px;"/>

            <HBox spacing="10">
                <Button text="View Results" onAction="#openResults"/>
                <Button text="View Courses" onAction="#openCourses"/>
            </HBox>

        </VBox>
    </center>

</BorderPane>