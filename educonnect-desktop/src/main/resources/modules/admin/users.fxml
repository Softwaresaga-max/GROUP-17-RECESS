<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.educonnect.controller.admin.UsersController">

    <!-- TOP BAR -->
    <top>
        <HBox spacing="10" style="-fx-padding: 10; -fx-background-color: #2c3e50;">

            <Label text="User Management"
                   style="-fx-text-fill: white; -fx-font-size: 18px;"/>

            <Region HBox.hgrow="ALWAYS"/>

            <!-- ACTION BUTTONS -->
            <Button text="+ Add User" onAction="#openAddUser"/>
            <Button text="Edit User" onAction="#editUser"/>
            <Button text="Delete User" onAction="#deleteUser"/>
            <Button text="Activate/Deactivate" onAction="#toggleStatus"/>

        </HBox>
    </top>


    <!-- TABLE -->
    <center>

        <TableView fx:id="userTable">

            <columns>

                <TableColumn fx:id="idCol"
                             text="ID"/>

                <TableColumn fx:id="nameCol"
                             text="Name"/>

                <TableColumn fx:id="emailCol"
                             text="Email"/>

                <TableColumn fx:id="roleCol"
                             text="Role"/>

                <TableColumn fx:id="statusCol"
                             text="Status"/>

            </columns>

        </TableView>

    </center>

</BorderPane>