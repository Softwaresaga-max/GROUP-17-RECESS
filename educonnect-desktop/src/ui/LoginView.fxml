<?xml version="1.0" encoding="UTF-8"?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="controllers.LoginController"
      alignment="CENTER"
      spacing="15"
      style="-fx-background-color: #0f172a; -fx-padding: 40;">

    <Label text="EDUCONNECT"
           style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: bold;"/>

    <TextField fx:id="emailField"
               promptText="Email"
               style="-fx-pref-width: 250;"/>

    <PasswordField fx:id="passwordField"
                   promptText="Password"
                   style="-fx-pref-width: 250;"/>

    <Button text="LOGIN"
            onAction="#handleLogin"
            style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-pref-width: 250;"/>

</VBox>