<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="450.0" prefWidth="600.0" spacing="15.0" style="-fx-background-color: #ffffff;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.educonnect.QuizController">
    <!-- Define the ToggleGroup cleanly outside the layout tree -->
    <fx:define>
        <ToggleGroup fx:id="optionsGroup" />
    </fx:define>

    <padding>
        <Insets bottom="20.0" left="25.0" right="25.0" top="20.0" />
    </padding>

    <!-- Quiz Title Header -->
    <HBox alignment="CENTER_LEFT" spacing="10.0">
        <Label fx:id="quizTitleLabel" text="EduConnect Knowledge Assessment" textFill="#2a52be">
            <font>
                <Font name="System Bold" size="18.0" />
            </font>
        </Label>
        <Region HBox.hgrow="ALWAYS" />
        <Label fx:id="progressLabel" text="Question 1 of 3" textFill="#666666">
            <font><Font name="System Bold" size="12.0" /></font>
        </Label>
    </HBox>

    <Separator />

    <!-- Question Box -->
    <VBox spacing="10.0" VBox.vgrow="ALWAYS">
        <Label fx:id="questionTextLabel" text="Question text will appear here..." wrapText="true">
            <font>
                <Font name="System Bold" size="14.0" />
            </font>
        </Label>

        <VBox spacing="10.0">
            <RadioButton fx:id="optionA" toggleGroup="$optionsGroup" wrapText="true" />
            <RadioButton fx:id="optionB" toggleGroup="$optionsGroup" wrapText="true" />
            <RadioButton fx:id="optionC" toggleGroup="$optionsGroup" wrapText="true" />
            <RadioButton fx:id="optionD" toggleGroup="$optionsGroup" wrapText="true" />
        </VBox>
    </VBox>

    <Separator />

    <!-- Action Controls -->
    <HBox alignment="CENTER_RIGHT" spacing="10.0">
        <Label fx:id="resultLabel" text="" textFill="#28a745">
            <font><Font name="System Bold" size="14.0" /></font>
        </Label>
        <Region HBox.hgrow="ALWAYS" />
        <Button fx:id="exportButton" disable="true" onAction="#handleExportReport" style="-fx-background-color: #17a2b8; -fx-text-fill: white; -fx-font-weight: bold;" text="Export Report 📄" />
        <Button fx:id="nextButton" onAction="#handleNextQuestion" style="-fx-background-color: #2a52be; -fx-text-fill: white; -fx-font-weight: bold;" text="Next Question ➔" />
    </HBox>
</VBox>