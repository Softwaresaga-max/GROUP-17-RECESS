<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="400.0" prefWidth="500.0" spacing="20.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.educonnect.AnalyticsController">
    <padding>
        <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
    </padding>

    <Label text="EduConnect Engagement Analytics" textFill="#2a52be">
        <font>
            <Font name="System Bold" size="18.0" />
        </font>
    </Label>

    <Separator />

    <GridPane vgap="15.0" hgap="15.0">
        <columnConstraints>
            <ColumnConstraints percentWidth="60.0" />
            <ColumnConstraints percentWidth="40.0" />
        </columnConstraints>

        <Label text="Total Registered Users:" GridPane.columnIndex="0" GridPane.rowIndex="0">
            <font><Font name="System Bold" size="14.0" /></font>
        </Label>
        <Label fx:id="totalUsersLabel" text="0" textFill="#2a52be" GridPane.columnIndex="1" GridPane.rowIndex="0">
            <font><Font name="System Bold" size="14.0" /></font>
        </Label>

        <Label text="Total Discussion Threads:" GridPane.columnIndex="0" GridPane.rowIndex="1">
            <font><Font name="System Bold" size="14.0" /></font>
        </Label>
        <Label fx:id="totalPostsLabel" text="0" textFill="#2a52be" GridPane.columnIndex="1" GridPane.rowIndex="1">
            <font><Font name="System Bold" size="14.0" /></font>
        </Label>

        <Label text="Total Replies &amp; Comments:" GridPane.columnIndex="0" GridPane.rowIndex="2">
            <font><Font name="System Bold" size="14.0" /></font>
        </Label>
        <Label fx:id="totalCommentsLabel" text="0" textFill="#2a52be" GridPane.columnIndex="1" GridPane.rowIndex="2">
            <font><Font name="System Bold" size="14.0" /></font>
        </Label>
    </GridPane>

    <Separator />

    <VBox spacing="8.0" style="-fx-background-color: #f4f4f4; -fx-padding: 12; -fx-background-radius: 5;">
        <Label text="Your Quiz Performance Overview">
            <font><Font name="System Bold" size="13.0" /></font>
        </Label>
        <Label fx:id="userQuizStatsLabel" text="Loading..." textFill="#555555" />
    </VBox>
</VBox>